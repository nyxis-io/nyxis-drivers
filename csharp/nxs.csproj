<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework Condition="'$(NxsTargetFramework)'!=''">$(NxsTargetFramework)</TargetFramework>
    <TargetFramework Condition="'$(NxsTargetFramework)'==''">net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <Optimize>true</Optimize>
    <AssemblyName>nxs</AssemblyName>
    <RootNamespace>Nxs</RootNamespace>

    <!-- NuGet package metadata -->
    <PackageId>nyxis</PackageId>
    <Version>1.2.1</Version>
    <Authors>Micael Malta</Authors>
    <Description>Zero-copy reader for the Nyxis (NXS) binary format. Provides O(1) random access to typed records via the tail-index.</Description>
    <!-- NuGet rejects non-OSI expressions (e.g. BUSL); ship the full license text instead. -->
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <PackageProjectUrl>https://github.com/nyxis-io/nyxis-drivers</PackageProjectUrl>
    <RepositoryUrl>https://github.com/nyxis-io/nyxis-drivers</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>nxs;binary;serialization;zero-copy;nyxis</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" Condition="Exists('README.md')" />
    <None Include="..\LICENSE" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="nxs.Tests/**" />
  </ItemGroup>
</Project>
